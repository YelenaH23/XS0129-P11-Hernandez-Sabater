# >>> ESCRIBA SU CODIGO AQUI:
install.packages("plotly")   # escriba aqui el nombre de su libreria
library(plotly)
ggplot( airquality,
aes(x = Temp, y = Ozone,
color = factor(Month))) +
geom_bar(size = 2) +
labs (
title = "Relacion entre Temperatura y Ozone",
x = "Temperatura",
y = "Ozone",
color = "Mes"
)
ggplot( airquality,
aes(x = Temp, y = Ozone,
color = factor(Month))) +
geom_bar(size = 2) +
labs (
title = "Relacion entre Temperatura y Ozone",
x = "Temperatura",
y = "Ozone",
color = "Mes"
)
ggplot( airquality,
aes(x = Temp, y = Ozone,
color = factor(Month))) +
geom_bar(size = 2) +
labs (
title = "Relacion entre Temperatura y Ozone",
x = "Temperatura",
y = "Ozone",
color = "Mes"
)
ggplot( airquality,
aes(x = Temp, y = Ozone,
color = factor(Month))) +
geom_point(size = 2) +
labs (
title = "Relacion entre Temperatura y Ozone",
x = "Temperatura",
y = "Ozone",
color = "Mes"
)
